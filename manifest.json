{
  "manifest_version": 3,
  "name": "Naver Blog SEO Analyzer",
  "version": "1.0.0",
  "description": "네이버 블로그 글쓰기 시 키워드 검색량과 경쟁도를 실시간으로 확인하세요",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*.workers.dev/*",
    "https://blog.naver.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://blog.naver.com/PostWriteForm.naver*",
        "https://blog.naver.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"]
    }
  ]
}
